# Variables de entorno para Docker Compose
# Copiar este archivo a .env y configurar los valores

# Configuración de Email (opcional)
EMAIL_ADMIN=pra.francisco.noman@cial.cl
EMAIL_SENDER=
EMAIL_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Configuración de seguridad (cambiar en producción)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ============================================
# INSTRUCCIONES PARA CONFIGURAR GMAIL:
# ============================================
# 1. Ve a tu cuenta de Google: https://myaccount.google.com/
# 2. Ve a Seguridad -> Verificación en dos pasos (actívala si no está activa)
# 3. Ve a Seguridad -> Contraseñas de aplicaciones
# 4. Selecciona "Correo" y "Otro (nombre personalizado)"
# 5. Escribe "OptimizaRutas" como nombre
# 6. Copia la contraseña de 16 caracteres generada
# 7. Pégala en EMAIL_PASSWORD arriba
# 8. Coloca tu correo en EMAIL_SENDER
# 9. Guarda este archivo como .env (sin .example)
# ============================================
