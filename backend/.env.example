# Variables de entorno de la aplicación
# Copiar este archivo a .env y configurar los valores

# Configuración general
APP_NAME=OptimizaRutas
DEBUG=True

# Seguridad JWT
SECRET_KEY=your-secret-key-change-this-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - Dominios permitidos (separados por comas)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Base de datos (archivos)
DATA_DIR=data
USERS_FILE=usuarios_sistema.xlsx
MAESTRO_FILE=Maestro APP.csv

# OSRM Server
OSRM_URL=http://localhost:5000
OSRM_DELAY_SECONDS=0.1

# Email (opcional)
EMAIL_ADMIN=admin@optimarutas.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=
